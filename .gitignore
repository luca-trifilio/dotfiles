.DS_Store
.envrc
# TPM installs plugins to ~/.tmux/plugins/ (outside this repo)
tmux/plugins/
/nvim/lazy-lock.json
/.claude/settings.local.json
karabiner/assets/
karabiner/automatic_backups/
# docs/ is populated via symlinks from the Obsidian vault, EXCEPT ADRs which are
# real repo decisions and must be versioned. Ignore docs/ contents but re-include
# docs/adr/ (a directory can't be re-included once its parent is fully ignored,
# so ignore /docs/* rather than /docs/).
/docs/*
!/docs/adr/
.claude/tasks/
