[user]
	name = Luca Trifilio
	email = luca.trifilio@gmail.com
	signingkey = ~/.ssh/id_ed25519.pub

[commit]
	gpgsign = true

[gpg]
	format = ssh

[core]
	autocrlf = input
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	features = catppuccin-mocha
	navigate = true
	side-by-side = true
	line-numbers = true

[merge]
	conflictstyle = diff3

[diff]
	colorMoved = default

[fetch]
	prune = true

[init]
	defaultBranch = main

[credential "https://github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential

[credential "https://gist.github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential

[credential]
	helper = osxkeychain

# Personal repos: force SSH via the `github-personal` alias so auth uses the
# personal key regardless of the active `gh` account (the HTTPS credential
# helper above would otherwise pick the work account on a work machine).
# Requires the `Host github-personal` block in ~/.ssh/config — managed by the
# Ansible macos role (ssh_github_personal_key var).
[url "git@github-personal:luca-trifilio/"]
	insteadOf = https://github.com/luca-trifilio/
	insteadOf = git@github.com:luca-trifilio/

[include]
	path = ~/.config/git/catppuccin.gitconfig

[include]
	path = ~/.gitconfig-local
