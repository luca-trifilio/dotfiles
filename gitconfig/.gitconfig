[user]
	name = Luca Trifilio
	email = luca.trifilio@gmail.com
	signingkey = ~/.ssh/id_ed25519.pub

[commit]
	gpgsign = true

[gpg]
	format = ssh

[core]
	autocrlf = input
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	features = catppuccin-mocha
	navigate = true
	side-by-side = true
	line-numbers = true

[merge]
	conflictstyle = diff3

[diff]
	colorMoved = default

[fetch]
	prune = true

[init]
	defaultBranch = main

[credential "https://github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential

[credential "https://gist.github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential

[credential]
	helper = osxkeychain

[include]
	path = ~/.config/git/catppuccin.gitconfig

[include]
	path = ~/.gitconfig-local
