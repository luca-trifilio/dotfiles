[user]
	email = luca.trifilio@gmail.com
	name = luca.trifilio
	signingkey = ~/.ssh/id_ed25519.pub
[commit]
	gpgsign = true
[gpg]
	format = ssh
[fetch]
	prune = true
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[init]
	defaultBranch = main
[core]
	autocrlf = input
	pager = delta
[interactive]
	diffFilter = delta --color-only
[include]
	path = ~/.config/git/catppuccin.gitconfig

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
	features = catppuccin-macchiato
[merge]
	conflictstyle = diff3
[diff]
	colorMoved = default

[includeIf "gitdir:~/Progetti/dotfiles/"]
	path = ~/.gitconfig-personal
[include]
	path = ~/.gitconfig-local
[credential]
	helper = osxkeychain
