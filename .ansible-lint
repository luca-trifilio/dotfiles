---
# Pragmatic ansible-lint config for a personal dotfiles repo.
# 'min' = only real errors (syntax, parsing, undefined). yamllint (.yamllint.yml)
# handles YAML style separately, so we don't double-enforce stylistic rules.
profile: min

exclude_paths:
  - .git/
  - docs/
  - ansible/group_vars/all/vault.sops.yaml
  - ansible/group_vars/work/vault.sops.yaml
