#!/bin/bash

VAULT_PATH="{{ obsidian_vault_path }}"
LOG="$HOME/obsidian-git.log"
cd "$VAULT_PATH" || exit 1

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$LOG"; }

# Single-writer setup: LiveSync is the source of truth, git is backup only.
# Remote can never be ahead of local, so no fetch/rebase needed.

# Guard: reject conflict markers on disk before they can be committed.
if grep -rlE '^(<<<<<<< |=======|>>>>>>> )' --include='*.md' . >> "$LOG" 2>&1; then
  log "ERROR: conflict markers on disk. Fix manually before next backup."
  exit 1
fi

git add .

if git diff --cached --quiet; then
  log "Nessun cambiamento."
  exit 0
fi

log "Cambiamenti rilevati. Committing..."
git commit -m "Backup automatico: $(date '+%Y-%m-%d %H:%M:%S')" >> "$LOG" 2>&1

log "Push su GitHub..."
if ! git push origin main >> "$LOG" 2>&1; then
  log "ERROR: Push GitHub fallito."
  exit 1
fi

log "Push su Forgejo..."
if ! git push forgejo main >> "$LOG" 2>&1; then
  log "ERROR: Push Forgejo fallito."
  exit 1
fi

log "Backup completato."
