#!/usr/bin/env bash

export CONFIG_DIR="$HOME/.config/sketchybar"
source "$CONFIG_DIR/helpers/constants.sh"

PLUGIN_DIR="$CONFIG_DIR/plugins"
ITEM_DIR="$CONFIG_DIR/items"

##### Bar #####
sketchybar --bar position=top \
                 height=$BAR_HEIGHT \
                 margin=0 \
                 y_offset=0 \
                 corner_radius=0 \
                 blur_radius=20 \
                 padding_left=8 \
                 padding_right=8 \
                 color=$BAR_COLOR \
                 border_width=0 \
                 sticky=on \
                 topmost=off \
                 font_smoothing=on

##### Defaults #####
sketchybar --default updates=when_shown \
                     icon.font="$FONT:Bold:14.0" \
                     icon.color=$TEXT \
                     icon.padding_left=$ICON_PADDING \
                     icon.padding_right=$ICON_PADDING \
                     label.font="$FONT:Semibold:13.0" \
                     label.color=$TEXT \
                     label.padding_left=$LABEL_PADDING \
                     label.padding_right=$LABEL_PADDING \
                     padding_left=$ITEM_PADDING \
                     padding_right=$ITEM_PADDING \
                     background.color=$ITEM_BG_COLOR \
                     background.corner_radius=$ITEM_CORNER_RADIUS \
                     background.height=$ITEM_HEIGHT \
                     background.drawing=off

##### Items #####
source "$ITEM_DIR/spaces.sh"
source "$ITEM_DIR/clock.sh"
source "$ITEM_DIR/battery.sh"
source "$ITEM_DIR/volume.sh"
source "$ITEM_DIR/ip_address.sh"
source "$ITEM_DIR/media.sh"

##### Finalize #####
sketchybar --update
(sleep 1 && sketchybar --trigger media_change) &

INITIAL_FOCUSED=$(aerospace list-workspaces --focused 2>/dev/null)
if [ -n "$INITIAL_FOCUSED" ]; then
  sketchybar --set space.$INITIAL_FOCUSED \
    icon.highlight=true \
    label.highlight=true \
    icon.color=$WORKSPACE_ICON_HIGHLIGHT_COLOR \
    label.color=$WORKSPACE_LABEL_HIGHLIGHT_COLOR \
    background.border_color=$WORKSPACE_ITEM_BORDER_HIGHLIGHT_COLOR
fi
