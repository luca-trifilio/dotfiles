#!/usr/bin/env bash
# Runs after `git pull` — re-applies non-sudo dotfiles roles automatically.
set -euo pipefail

DOTFILES_DIR="$(git -C "$(dirname "$0")" rev-parse --show-toplevel)"
ANSIBLE_DIR="$DOTFILES_DIR/ansible"

case "$(hostname -s)" in
  0876-Pro-14)             LIMIT=work-mac ;;
  MacBook-Pro-M4-Max-di-Luca) LIMIT=personal-mac ;;
  *) echo "dotfiles: unknown hostname, skipping ansible"; exit 0 ;;
esac

echo "==> dotfiles: running ansible (shell, stow, install) for $LIMIT..."
cd "$ANSIBLE_DIR"
SOPS_AGE_KEY_FILE="${HOME}/.config/sops/age/keys.txt" \
  ansible-playbook playbooks/site.yml \
  --limit "$LIMIT" \
  --tags shell,stow,install 2>&1
